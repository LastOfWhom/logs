{
    "name": "log-service/log-service",
    "description": "Microservice for collecting, processing and publishing logs via RabbitMQ",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "ext-amqp": "*",
        "symfony/framework-bundle": "^7.0",
        "symfony/console": "^7.0",
        "symfony/dotenv": "^7.0",
        "symfony/flex": "^2",
        "symfony/messenger": "^7.0",
        "symfony/amqp-messenger": "^7.0",
        "symfony/uid": "^7.0",
        "symfony/monolog-bundle": "^3.0",
        "symfony/runtime": "^7.0",
        "symfony/yaml": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/browser-kit": "^7.0",
        "symfony/http-client": "^7.0",
        "phpstan/phpstan": "^1.10",
        "symfony/phpunit-bridge": "^7.0"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": [],
        "post-update-cmd": []
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.*"
        }
    }
}
